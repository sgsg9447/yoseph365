# Supabase — 로컬 개발(supabase start 출력값으로 채움)
# 운영 시에는 Supabase 프로젝트 대시보드의 값으로 교체
# 로컬: supabase start 출력값 / 운영(Vercel): 클라우드 프로젝트 대시보드 값
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# 서버 전용(관리자 작업·시드). 절대 클라이언트에 노출 금지
SUPABASE_SECRET_KEY=

# 이메일 알림 (Resend) — 신청·문의 운영자 알림 / Type A 접수 안내
RESEND_API_KEY=

# S3 (훈련사진 등 이미지) — 어드민 presigned 업로드
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
